# NoomiBodi Environment Configuration
# Copy this file to .env for development or .env.production for production.
# Switching: set APP_ENV=production before building to load .env.production.
# IMPORTANT: clear Metro cache after switching: npx react-native start --reset-cache

# Supabase — get from supabase.com/dashboard → Project Settings → API Keys
SUPABASE_URL=https://your-dev-project-ref.supabase.co
SUPABASE_ANON_KEY=your-dev-supabase-anon-key

# Google Sign-In — get from Google Cloud Console → Credentials → OAuth 2.0 Client IDs
GOOGLE_WEB_CLIENT_ID=your-google-web-client-id.apps.googleusercontent.com
GOOGLE_IOS_CLIENT_ID=your-google-ios-client-id.apps.googleusercontent.com
