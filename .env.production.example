# NoomiBodi PRODUCTION Environment
# Copy this file to .env.production and fill in your production values.
# This file is loaded when APP_ENV=production is set before building.
# IMPORTANT: clear Metro cache after switching: npx react-native start --reset-cache

# Supabase PRODUCTION — get from supabase.com/dashboard → Project Settings → API Keys
SUPABASE_URL=https://your-prod-project-ref.supabase.co
SUPABASE_ANON_KEY=your-prod-supabase-anon-key

# Google Sign-In — same OAuth client IDs work for both environments
GOOGLE_WEB_CLIENT_ID=your-google-web-client-id.apps.googleusercontent.com
GOOGLE_IOS_CLIENT_ID=your-google-ios-client-id.apps.googleusercontent.com
